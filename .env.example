# ── Mapbox (set this on the SimSat Docker side too) ───────────
# Get a free token at https://www.mapbox.com/
# SimSat needs this to serve satellite imagery via its API.
MAPBOX_ACCESS_TOKEN=

# ── Satellite API ──────────────────────────────────────────────
ARGUS_API_URL=http://localhost:9005
ARGUS_SIMSAT_API_URL=http://localhost:9005
ARGUS_HTTP_TIMEOUT=30

# ── VLM (LFM2.5-VL — the core of the pipeline) ──────────────
ARGUS_VLM_MODEL=LiquidAI/LFM2.5-VL-450M
ARGUS_VLM_MAX_TOKENS=512

# ── Depth Analysis (DA3 — decoy verification) ────────────────
ARGUS_DA3_MODEL=depth-anything/DA3-BASE
ARGUS_DEPTH_THRESH=0.1

# ── Ghost Image Filtering ────────────────────────────────────
# Pixel std below this → ocean/blank frame, skip
ARGUS_GHOST_STD=10.0

# ── Minimum crop size (pixels) ───────────────────────────────
ARGUS_MIN_CROP_PX=10

# ── Scanning ──────────────────────────────────────────────────
# Set to 0 for a single-shot scan (no loop)
ARGUS_SCAN_INTERVAL=1

# ── Logging ───────────────────────────────────────────────────
ARGUS_LOG_LEVEL=INFO
